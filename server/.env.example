# Cấu hình server
PORT=5000
SESSION_SECRET=replace_with_a_strong_secret

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/learnloom

# CORS: danh sách origin frontend, ngăn cách bằng dấu phẩy
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# URL cơ sở dùng cho VNPay return/redirect
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:5000

# Google OAuth
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret

# Gemini AI
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Chat limits
CHAT_HISTORY_LIMIT=20
CHAT_MAX_MESSAGE_LENGTH=4000

# VNPay sandbox (đăng ký tại https://sandbox.vnpayment.vn/devreg/ để lấy TMN_CODE và HASH_SECRET)
VNPAY_TMN_CODE=replace_with_vnpay_tmn_code
VNPAY_HASH_SECRET=replace_with_vnpay_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# DEV-ONLY: khi VNPay sandbox credentials chưa có hoặc bị lỗi,
# set VNPAY_MOCK_MODE=true để giả lập callback thanh toán nội bộ
# (không gọi VNPay thật, phục vụ demo/dev). PHẢI tắt khi production.
VNPAY_MOCK_MODE=false
